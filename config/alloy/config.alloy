logging {
  level  = "info"
  format = "logfmt"
}

// --- NODE METRICS ---
prometheus.exporter.unix "node_metics" { }

prometheus.scrape "node_metics" {
  targets    = prometheus.exporter.unix.node_metics.targets
  forward_to = [prometheus.remote_write.node_metics.receiver]
}

// --- ALLOY METRICS ---
prometheus.exporter.self "alloy_metrics" { }

prometheus.scrape "alloy_scrape" {
  targets    = prometheus.exporter.self.self_metrics.targets
  forward_to = [prometheus.remote_write.mimir.receiver]
}

prometheus.remote_write "mimir" {
  endpoint {
    url = "http://nginx:9009"
  }
}

// --- END METRICS ---

// --- START LOGS ---

// --- LOGS (Docker Containers) ---
discovery.docker "containers" {
  host 							= "unix:///var/run/docker.sock"
	refresh_interval 	= "5s"
}

discovery.relabel "containers" {
	targets = []

	rule {
		source_labels = ["__meta_docker_container_name"]
		regex         = "/(.*)"
		target_label  = "container"
	}
}

loki.source.docker "docker_logs" {
	host						= "unix:///var/run/docker.sock"
  targets					= discovery.docker.containers.targets
  forward_to 			= [loki.write.docker_logs.receiver]
	relabel_rules		= discovery.relabel.containers.rules
}

loki.write "docker_logs" {
  endpoint {
    url 			= "http://nginx:3100/loki/api/v1/push"
		tenant_id = "tenant1"
  }
}

// --- END LOGS --- 

